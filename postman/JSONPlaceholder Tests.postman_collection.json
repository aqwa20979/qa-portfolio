  "item": [
    {
      "name": "GET Post by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Проверка 1: статус ответа 200\r",
              "pm.test(\"Статус ответа 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Проверка 2: тело ответа — это объект, а не массив\r",
              "pm.test(\"Ответ содержит данные одного поста\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data).to.be.an('object');\r",
              "});\r",
              "\r",
              "// Проверка 3: у поста есть поле id\r",
              "pm.test(\"Пост содержит поле id\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data).to.have.property('id');\r",
              "});\r",
              "\r",
              "// Проверка 4: id поста равен 1\r",
              "pm.test(\"ID поста равен 1\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.id).to.eql(1);\r",
              "});\r",
              "\r",
              "// Проверка 5: у поста есть поле title\r",
              "pm.test(\"Пост содержит поле title\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data).to.have.property('title');\r",
              "});\r",
              "\r",
              "// Проверка 6: title не пустой\r",
              "pm.test(\"Заголовок поста не пустой\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.title).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
